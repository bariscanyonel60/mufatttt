# Resend (https://resend.com) — iletişim ve kariyer formları
RESEND_API_KEY=
# Doğrulanmış domain’den gönderici (yoksa Resend onboarding adresi kullanılır)
RESEND_FROM_EMAIL=
# Alıcı — iletişim formu (yoksa site.email)
CONTACT_TO_EMAIL=
# Alıcı — kariyer başvuruları
CAREER_TO_EMAIL=insankaynaklari@mufatinsaat.com

# Yönetici paneli (/admin) — production’da mutlaka güçlü değerler kullanın
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
ADMIN_SECRET=

# Cloudinary (https://cloudinary.com) — admin medya + hero video + CV
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Client-side delivery (hero video / poster)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Analytics (çerez onayı sonrası yüklenir)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ornek.com

# Cloudflare Turnstile (opsiyonel — ikisi de boşsa formlarda kapalı)
# Site key ve secret MUTLAKA birlikte set edilmeli; yalnızca biri dolu olursa
# istemci doğrulama isterken sunucu reddedebilir (veya tersi).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# İsteğe bağlı public override’lar
# NEXT_PUBLIC_SITE_PHONE=
# NEXT_PUBLIC_SITE_WHATSAPP=
# NEXT_PUBLIC_SITE_EMAIL=
# NEXT_PUBLIC_SITE_ADDRESS=
# NEXT_PUBLIC_SITE_URL=https://www.mufatinsaat.com
# NEXT_PUBLIC_SITE_MAP_EMBED=
# NEXT_PUBLIC_SITE_INSTAGRAM=
# NEXT_PUBLIC_SITE_LINKEDIN=
# NEXT_PUBLIC_SITE_FACEBOOK=

# MySQL (opsiyonel — Guzel Hosting; Vercel’de kalıcılık için gerekli)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
